# ====== Catatan Keuangan Pocong - Konfigurasi ======

# Port untuk server dashboard
PORT=3000

# ====== Google Sheets ======
# ID spreadsheet (ambil dari URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit)
GOOGLE_SHEET_ID=masukkan_id_spreadsheet_disini
# Path ke file kredensial service account (buat di Google Cloud Console)
GOOGLE_CREDENTIALS=./credentials.json

# ====== Telegram ======
# Token dari @BotFather (kosongkan jika tidak ingin menggunakan Telegram)
TELEGRAM_TOKEN=masukkan_token_telegram_disini
# (opsional) Batasi hanya chat ID tertentu yang boleh memakai bot, pisahkan koma
TELEGRAM_ALLOWED_IDS=

# ====== Dashboard ======
# URL dashboard publik untuk tombol/link Telegram (isi dengan URL Railway jika sudah deploy)
# Jika Railway menyediakan RAILWAY_PUBLIC_DOMAIN, aplikasi bisa otomatis memakai domain itu.
DASHBOARD_URL=

# ====== WhatsApp ======
# Aktifkan WhatsApp bot (true/false). Saat true, scan QR di terminal saat start.
WHATSAPP_ENABLED=false
# (opsional) Batasi hanya nomor tertentu, format: 6281234567890, pisahkan koma
WHATSAPP_ALLOWED_NUMBERS=

# ====== Budget bulanan ======
# Total budget pengeluaran per bulan (angka, tanpa titik/koma)
MONTHLY_BUDGET=5000000

# ====== AI-Powered Receipt Parsing (OPSIONAL) ======
# Pilih SALAH SATU (atau keduanya). Prioritas: Gemini > Claude > OCR biasa.

# OPSI A: Google Gemini (REKOMENDASI - bisa baca gambar langsung!)
# Dapatkan API key gratis dari: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=masukkan_gemini_api_key_disini

# OPSI B: Anthropic Claude (perlu OCR text dulu)
# Dapatkan dari: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=

# ====== Google Credentials JSON (UNTUK CLOUD/RAILWAY) ======
# Untuk deployment di Railway/cloud, masukkan isi credentials.json di sini
# Jika lokal, biarkan kosong (gunakan file credentials.json saja)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
