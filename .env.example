# ====== Catatan Keuangan Pocong - Konfigurasi ======

# Port untuk server dashboard
PORT=3000

# ====== Google Sheets ======
# ID spreadsheet (ambil dari URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit)
GOOGLE_SHEET_ID=masukkan_id_spreadsheet_disini
# Path ke file kredensial service account (buat di Google Cloud Console)
GOOGLE_CREDENTIALS=./credentials.json

# ====== Telegram ======
# Token dari @BotFather (kosongkan jika tidak ingin menggunakan Telegram)
TELEGRAM_TOKEN=masukkan_token_telegram_disini
# (opsional) Batasi hanya chat ID tertentu yang boleh memakai bot, pisahkan koma
TELEGRAM_ALLOWED_IDS=

# ====== WhatsApp ======
# Aktifkan WhatsApp bot (true/false). Saat true, scan QR di terminal saat start.
WHATSAPP_ENABLED=false
# (opsional) Batasi hanya nomor tertentu, format: 6281234567890, pisahkan koma
WHATSAPP_ALLOWED_NUMBERS=

# ====== Budget bulanan ======
# Total budget pengeluaran per bulan (angka, tanpa titik/koma)
MONTHLY_BUDGET=5000000
